{
  "name": "@tauri-vuetify-starter/frontend",
  "version": "0.0.0",
  "description": "A modern desktop application built with Tauri v2 and Vue 3",
  "license": "MIT",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "sync:env": "cd .. && node ./scripts/sync-env-config.mjs",
    "dev:tauri": "pnpm run sync:env && cd .. && RUST_LOG=info CARGO_INCREMENTAL=1 tauri dev --config backend/tauri.conf.json",
    "clean": "rimraf ./node_modules/.vite",
    "build": "run-p type-check \"build-only {@}\" build:tauri --",
    "build:analyze": "vite build --mode analyze",
    "build:clean": "rimraf dist",
    "build:tauri": "pnpm run sync:env && cd .. && tauri build --config backend/tauri.conf.json",
    "build:tauri:mac": "pnpm run sync:env && cd .. && tauri build --config backend/tauri.conf.json --target universal-apple-darwin",
    "build:tauri:windows-x64": "pnpm run sync:env && cd .. && tauri build --config backend/tauri.conf.json --target x86_64-pc-windows-msvc",
    "build:tauri:windows-arm64": "pnpm run sync:env && cd .. && tauri build --config backend/tauri.conf.json --target aarch64-pc-windows-msvc",
    "build:tauri:windows-docker-x64": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'pwsh ..\\\\scripts\\\\build-linux-docker.ps1 -Target x64' : 'bash ../scripts/build-linux-docker.sh x64', {stdio: 'inherit'})\"",
    "build:tauri:windows-docker-arm64": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'pwsh ..\\\\scripts\\\\build-linux-docker.ps1 -Target arm64' : 'bash ../scripts/build-linux-docker.sh arm64', {stdio: 'inherit'})\"",
    "build:tauri:linux-x64": "cd .. && tauri build --config backend/tauri.conf.json --target x86_64-unknown-linux-gnu",
    "build:tauri:linux-arm64": "cd .. && tauri build --config backend/tauri.conf.json --target aarch64-unknown-linux-gnu",
    "build:tauri:linux-docker-x64": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'pwsh ..\\\\scripts\\\\build-linux-docker.ps1 -Target x64' : 'bash ../scripts/build-linux-docker.sh x64', {stdio: 'inherit'})\"",
    "build:tauri:linux-docker-arm64": "node -e \"require('child_process').execSync(process.platform === 'win32' ? 'pwsh ..\\\\scripts\\\\build-linux-docker.ps1 -Target arm64' : 'bash ../scripts/build-linux-docker.sh arm64', {stdio: 'inherit'})\"",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache --cache-location ./node_modules/.vite/eslint-cache",
    "lint:prettier": "prettier \"./**/*.{js,ts,json,css,sass,scss,htm,html,vue,md}\" -w -u",
    "lint:style": "stylelint \"./**/*.{css,sass,scss,htm,html,vue}\" --fix --cache-location ./node_modules/.vite/stylelint-cache && prettier \"./**/*.{css,sass,scss,htm,html,vue}\" -w -u",
    "tauri": "tauri"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "core-js": "^3.49.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2",
    "vuetify": "^4.0.7"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jiti": "^2.7.0",
    "jsdom": "29.1.1",
    "resize-observer-polyfill": "^1.5.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.0.13",
    "vite-plugin-checker": "0.13.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.9"
  }
}
