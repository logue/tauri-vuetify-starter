{
  "name": "@tauri-vuetify-starter/docs",
  "description": "Documentation site for tauri-vuetify-starter application",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "postbuild": "cp .output/public/index.html .output/public/404.html && touch .output/public/.nojekyll",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "postgenerate": "cp .output/public/index.html .output/public/404.html && touch .output/public/.nojekyll",
    "preview": "nuxt preview",
    "clean": "rimraf .nuxt .output public/_nuxt",
    "clean:full": "rimraf .nuxt .output public/_nuxt node_modules/.vite node_modules/.cache",
    "clean:reinstall": "pnpm run clean:full && pnpm install",
    "deploy": "nuxt generate && gh-pages -d .output/public -b main",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache --cache-location ./node_modules/.vite/eslint-cache",
    "lint:prettier": "prettier \"./**/*.{js,ts,json,css,sass,scss,htm,html,vue,md}\" -w -u",
    "lint:style": "stylelint \"./**/*.{css,sass,scss,htm,html,vue}\" --fix --cache-location ./node_modules/.vite/stylelint-cache && prettier \"./**/*.{css,sass,scss,htm,html,vue}\" -w -u",
    "nuxt:prepare": "nuxt prepare",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@nuxt/content": "^3.14.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/i18n": "^10.3.0",
    "@nuxtjs/sitemap": "^8.0.15",
    "@pinia/nuxt": "^0.11.3",
    "better-sqlite3": "12.10.0",
    "nuxt": "^4.4.6",
    "nuxt-gtag": "^4.1.0",
    "pinia": "^3.0.4",
    "ufo": "^1.6.4",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "vuetify": "^4.0.7",
    "vuetify-nuxt-module": "1.0.0-beta.4",
    "zod": "^4.4.3"
  }
}
